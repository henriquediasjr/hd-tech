APP_ENV=development
APP_TITLE=Portfolio API
APP_VERSION=0.1.0
CORS_ORIGINS=["http://localhost:5173"]
CALENDLY_URL=https://calendly.com/your-username

# Email — Gmail SMTP
# 1. Enable 2-Step Verification on your Google account
# 2. Go to myaccount.google.com/apppasswords and create an App Password
# 3. Paste the 16-character App Password below (no spaces)
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
CONTACT_EMAIL=henriquediasjr@gmail.com

# PostgreSQL — matches docker-compose.yml credentials
# host port is 5433 to avoid conflicts with a local postgres on 5432
# DATABASE_URL=postgresql+asyncpg://portfolio:portfolio@db:5432/portfolio
